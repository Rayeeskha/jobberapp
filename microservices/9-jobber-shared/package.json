{
  "version": "0.3.14",
  "license": "MIT",
  "types": "./src/index.d.ts",
  "description": "Helpers library for Jobber app",
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && tsc --outDir build/src && node scripts/build-package.js",
    "build:cjs": "cross-env NODE_ENV=production BABEL_ENV=cjs babel src --presets=./scripts/babel-preset.js --extensions .ts,.tsx --ignore src/**/*.specs.tsx --out-dir build/cjs --source-maps",
    "build:esm": "cross-env NODE_ENV=production BABEL_ENV=esm babel src --presets=./scripts/babel-preset.js --extensions .ts,.tsx --ignore src/**/*.specs.tsx --out-dir build/esm --source-maps"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "keywords": [],
  "name": "@rayeeskha/jobber-shared",
  "author": "Rayees khan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rayeeskha/jobber-shared.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "build",
    "src"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js"
    }
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.1.1",
    "@types/elasticsearch": "^5.0.43",
    "cloudinary": "^2.1.0",
    "cross-env": "^10.1.0",
    "elastic-apm-node": "^4.15.0",
    "elasticsearch": "^16.7.3",
    "express": "^5.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.4",
    "tslib": "^2.8.1",
    "winston": "^3.13.0",
    "winston-elasticsearch": "^0.17.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.1",
    "@babel/preset-env": "^7.24.3",
    "@babel/preset-typescript": "^7.24.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
