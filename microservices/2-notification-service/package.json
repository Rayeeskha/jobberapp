{
  "name": "jobber-notification-service",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "pm2 start ./build/src/app.js -i 5 --attach --watch | pino-pretty -c",
    "stop": "pm2 stop all",
    "delete": "pm2 delete all",
    "dev": "nodemon -r tsconfig-paths/register src/app.ts | pino-pretty -c",
    "lint:check": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "prettier:check": "prettier --check 'src/**/*.{ts,json}'",
    "prettier:fix": "prettier --write 'src/**/*.{ts,json}'",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json && ts-node tools/copyAssets.ts",
    "test": "jest --coverage=true -w=1 --forceExit --detectOpenHandles --watchAll=false"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@jest/types": "^29.6.3",
    "@types/amqplib": "^0.10.8",
    "@types/email-templates": "^10.0.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.7",
    "@types/nodemailer": "^8.0.0",
    "@types/shelljs": "^0.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@rayeeskha/jobber-shared": "^0.3.11",
    "amqplib": "^1.0.3",
    "dotenv": "^17.4.1",
    "ejs": "^3.1.10",
    "email-templates": "^13.0.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "fs-extra": "^11.3.4",
    "http-status-codes": "^2.3.0",
    "nodemailer": "^8.0.5",
    "pino-pretty": "^13.1.3",
    "shelljs": "^0.10.0",
    "typescript-transform-paths": "^3.5.6",
    "winston": "^3.19.0"
  }
}
